<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
    <schema path="/org/gnome/shell/extensions/statlens/"
        id="org.gnome.shell.extensions.statlens">
        <key name="set-api-key" type="s">
            <default>''</default>
            <summary>Set CoinGecko API Key</summary>
            <description>API key from the CoinGecko.</description>
        </key>
        <key name="set-refresh-interval" type="i">
            <default>300</default>
            <range min="10" max="600"/>
            <summary>Set Refresh interval</summary>
            <description>How often to fetch new data, in seconds.</description>
        </key>
        <key name="set-display-currency" type="s">
            <default>"usd"</default>
            <choices>
                <choice value="usd"/>
                <choice value="eur"/>
                <choice value="btc"/>
            </choices>
            <summary>Set Display Currency</summary>
            <description>Which currency to display prices in.</description>
        </key>
        <key name="set-enabled-stats" type="as">
            <default>['price', 'change', 'sparkline', 'volume', 'hl', 'supply', 'mc', 'fdv']</default>
            <summary>Set Enabled Stats</summary>
            <description>Which stats to show in the menu.</description>
        </key>
        <key name="set-price-alarms" type="a(db)">
            <default>[]</default>
            <summary>Set Price Alarms</summary>
            <description>Up to 5 one-shot SHX/USD price targets.</description>
        </key>
        <key name="set-prefs-target-page" type="s">
            <default>''</default>
            <summary>Preferences Target Page</summary>
            <description>(Internal) Which page to show next time preferences opens.</description>
        </key>
    </schema>
</schemalist>
